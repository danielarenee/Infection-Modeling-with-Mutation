Cell[BoxData[
 RowBox[{
  RowBox[{"\[Mu]", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Mu]", "3"], " ", 
      RowBox[{"(", 
       RowBox[{"\[Alpha]", "-", "\[Beta]", "+", "\[Mu]"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "\[Sigma]"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "\[Gamma]p"}], "+", 
        RowBox[{"\[Delta]p", " ", "\[Sigma]"}]}], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox["II", "4"], " ", 
      SuperscriptBox["\[Beta]", "2"], " ", "\[Gamma]p", " ", "\[Delta]p", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[Alpha]", "2"], " ", "\[Gamma]p"}], "+", 
        RowBox[{"\[Alpha]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", "\[Gamma]p", " ", "\[Mu]"}], "-", 
           RowBox[{"\[Beta]", " ", "\[Sigma]"}]}], ")"}]}], "+", 
        RowBox[{"\[Mu]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Gamma]p", " ", "\[Mu]"}], "-", 
           RowBox[{"\[Beta]", " ", "\[Sigma]", " ", 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"\[Delta]p", " ", "\[Sigma]"}]}], ")"}]}]}], ")"}]}]}], 
       ")"}]}], "+", 
     RowBox[{"II", " ", 
      SuperscriptBox["\[Mu]", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[Alpha]", "2"], " ", "\[Gamma]p", " ", 
         RowBox[{"(", 
          RowBox[{"\[Gamma]p", "+", "\[Delta]p", "-", 
           RowBox[{"2", " ", "\[Delta]p", " ", "\[Sigma]"}]}], ")"}]}], "+", 
        RowBox[{"2", " ", "\[Alpha]", " ", "\[Gamma]p", " ", "\[Mu]", " ", 
         RowBox[{"(", 
          RowBox[{"\[Gamma]p", "+", "\[Delta]p", "-", 
           RowBox[{"2", " ", "\[Delta]p", " ", "\[Sigma]"}]}], ")"}]}], "+", 
        RowBox[{"\[Gamma]p", " ", 
         SuperscriptBox["\[Mu]", "2"], " ", 
         RowBox[{"(", 
          RowBox[{"\[Gamma]p", "+", "\[Delta]p", "-", 
           RowBox[{"2", " ", "\[Delta]p", " ", "\[Sigma]"}]}], ")"}]}], "-", 
        RowBox[{"\[Alpha]", " ", "\[Beta]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "\[Delta]p"}], " ", 
            RowBox[{"(", 
             RowBox[{"3", "+", "\[Delta]p"}], ")"}], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "\[Sigma]"}], ")"}], " ", "\[Sigma]"}],
            "+", 
           RowBox[{
            SuperscriptBox["\[Gamma]p", "2"], " ", 
            RowBox[{"(", 
             RowBox[{"1", "+", "\[Sigma]"}], ")"}]}], "+", 
           RowBox[{"\[Gamma]p", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "3"}], "+", "\[Delta]p", "+", 
