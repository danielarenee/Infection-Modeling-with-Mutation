Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", 
       RowBox[{"-", "ENDEMIC"}]}]}], " ", "EQUILIBRIUM", " ", "FOR", " ", 
     RowBox[{
      RowBox[{"SIRCm", "--"}], "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Set", " ", "all", " ", "derivatives", " ", "to", " ", "zero"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eqEqs", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"dS", "==", "0"}], ",", 
       RowBox[{"dI", "==", "0"}], ",", 
       RowBox[{"dR", "==", "0"}], ",", 
       RowBox[{"dC", "==", "0"}]}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Divide", " ", "the", " ", "dI", " ", "equation", " ", "by", " ", "II", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"assuming", " ", "II"}], "!=", 
       RowBox[{"0", " ", "for", " ", "endemic", " ", "state"}]}], ")"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eqI", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Beta]", "*", "S"}], "+", 
       RowBox[{"\[Sigma]", "*", "\[Beta]", "*", "CC"}]}], "==", 
      RowBox[{"\[Mu]", "+", "\[Alpha]"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Rebuild", " ", "the", " ", "system", " ", "with", " ", "the", " ", 
      "reduced", " ", "I"}], "-", "equation"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eqSystem", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"dS", "==", "0"}], ",", "eqI", ",", 
       RowBox[{"dR", "==", "0"}], ",", 
       RowBox[{"dC", "==", "0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Eliminate", " ", "S"}], ",", "R", ",", 
     RowBox[{
     "and", " ", "CC", " ", "to", " ", "get", " ", "an", " ", "equation", " ",
       "only", " ", "in", " ", "terms", " ", "of", " ", "II"}]}], "*)"}], "\n", 
   RowBox[{"Print", "[", "\"\<\\nEliminating S, R, CC... \>\"", "]"}], "\n", 
   RowBox[{
    RowBox[{"reduced", "=", 
     RowBox[{
      RowBox[{"Eliminate", "[", 
       RowBox[{"eqSystem", ",", 
        RowBox[{"{", 
         RowBox[{"S", ",", "R", ",", "CC"}], "}"}]}], "]"}], "//", 
      "Simplify"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", "\"\<\\nReduced equation in I only:\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", "reduced", "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Extract", " ", "the", " ", "left", " ", "side", " ", "of", " ", "the", " ",
      "equation", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"assuming", " ", "it", " ", "outputs", " ", "Expression"}], "==",
        "0"}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"poly", "=", 
     RowBox[{"reduced", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Collect", " ", "terms", " ", "by", " ", "powers", " ", "of", " ", "II", " ",
      "to", " ", "see", " ", "the", " ", "degree", " ", "of", " ", "the", " ",
      "polynomial"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"polyI", "=", 
     RowBox[{"Collect", "[", 
      RowBox[{"poly", ",", "II", ",", "Simplify"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<\\nPolynomial collected by powers of I:\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", "polyI", "]"}]}]}]], "Input",
