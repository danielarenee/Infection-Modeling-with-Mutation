Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "we", " ", "set", " ", "all", " ", "derivatives", " ", "to", " ", "zero"}],
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eqEqs", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"dS", "==", "0"}], ",", 
       RowBox[{"dI", "==", "0"}], ",", 
       RowBox[{"dR", "==", "0"}], ",", 
       RowBox[{"dC", "==", "0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "divide", " ", "the", " ", "dI", " ", "equation", " ", "by", " ", "II", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"because", " ", "we", " ", "are", " ", "assuming", " ", "II"}],
        "!=", 
       RowBox[{"0", " ", "for", " ", "endemic", " ", "state"}]}], ")"}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"eqI", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Beta]", "*", "S"}], "+", 
       RowBox[{"\[Sigma]", "*", "\[Beta]", "*", "CC"}]}], "==", 
      RowBox[{"\[Mu]", "+", "\[Alpha]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"and", " ", "rebuild", " ", "the", " ", "system"}], "*)"}], "\n", 
   
   RowBox[{
    RowBox[{"eqSystem", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"dS", "==", "0"}], ",", "eqI", ",", 
       RowBox[{"dR", "==", "0"}], ",", 
       RowBox[{"dC", "==", "0"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"eliminate", " ", "S"}], ",", "R", ",", 
     RowBox[{
     "and", " ", "CC", " ", "to", " ", "get", " ", "a", " ", "reduced", " ", 
      "equation", " ", "only", " ", "in", " ", "terms", " ", "of", " ", 
      "II"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"reduced", "=", 
     RowBox[{
      RowBox[{"Eliminate", "[", 
       RowBox[{"eqSystem", ",", 
        RowBox[{"{", 
         RowBox[{"S", ",", "R", ",", "CC"}], "}"}]}], "]"}], "//", 
      "Simplify"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", "\"\<\\nReduced equation in I only:\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", "reduced", "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"lets", " ", "extract", " ", "the", " ", "left", " ", "side"}], 
     "..."}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"poly", "=", 
     RowBox[{"reduced", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "and", " ", "collect", " ", "by", " ", "powers", " ", "of", " ", "II", " ",
      "to", " ", "see", " ", "the", " ", "degree", " ", "of", " ", "the", " ",
      "polynomial"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"polyI", "=", 
     RowBox[{"Collect", "[", 
      RowBox[{"poly", ",", "II", ",", "Simplify"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<\\nPolynomial collected by powers of I:\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", "polyI", "]"}], "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{
  3.9910332948993597`*^9, {3.991033479491136*^9, 3.99103351315693*^9}, {
   3.9910335906662197`*^9, 3.9910336269708853`*^9}, {3.991033687181046*^9, 
