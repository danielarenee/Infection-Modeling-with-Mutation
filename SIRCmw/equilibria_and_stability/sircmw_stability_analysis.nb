Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"vars", "=", 
     RowBox[{"{", 
      RowBox[{"S", ",", "II", ",", "R", ",", "CC"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rhs", "=", 
     RowBox[{"{", 
      RowBox[{"dS", ",", "dI", ",", "dR", ",", "dC"}], "}"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"now", " ", "we", " ", "get", " ", "the", " ", "jacobian"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"J", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{"rhs", ",", 
        RowBox[{"{", "vars", "}"}]}], "]"}], "//", "Simplify"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"and", " ", "evaluate", " ", "in", " ", "X_", "0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"JDFE", "=", 
     RowBox[{
      RowBox[{"J", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"S", "->", "1"}], ",", 
         RowBox[{"II", "->", "0"}], ",", 
         RowBox[{"R", "->", "0"}], ",", 
         RowBox[{"CC", "->", "0"}]}], "}"}]}], "//", "Simplify"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", "\"\<Jacobian at DFE:\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"JDFE", "//", "MatrixForm"}], "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "now", " ", "we", " ", "compute", " ", "the", " ", "eigenvalues"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"evalsDFE", "=", 
     RowBox[{
      RowBox[{"Eigenvalues", "[", "JDFE", "]"}], "//", "Simplify"}]}], ";"}], 
   "\n", 
   RowBox[{"Print", "[", "\"\<\\nEigenvalues at DFE:\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", "evalsDFE", "]"}]}]}]], "Input",
