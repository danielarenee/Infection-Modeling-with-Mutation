Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"first", " ", "lets", " ", "define", " ", "the", " ", 
    RowBox[{"model", ":"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"we", " ", "are", " ", "assuming", " ", "\[Epsilon]1"}], " ", "=",
     " ", 
    RowBox[{"\[Epsilon]2", " ", "=", " ", "\[Epsilon]"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", "\n", 
   RowBox[{
    RowBox[{"dS", "=", 
     RowBox[{
      RowBox[{"\[Mu]", "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", "S"}], ")"}]}], "-", 
      RowBox[{"\[Beta]", "*", "S", "*", "II"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", " ", 
         RowBox[{"\[Epsilon]", "*", "S", "*", "II"}]}], ")"}], "*", 
       "\[Gamma]", "*", "CC"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dI", "=", 
     RowBox[{
      RowBox[{"\[Beta]", "*", "S", "*", "II"}], "+", 
      RowBox[{"\[Sigma]", "*", "\[Beta]", "*", "CC", "*", "II"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Mu]", "+", "\[Alpha]"}], ")"}], "*", "II"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dR", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Sigma]"}], ")"}], "*", "\[Beta]", "*", "CC", "*",
        "II"}], "+", 
      RowBox[{"\[Alpha]", "*", "II"}], "-", 
      RowBox[{"\[Mu]", "*", "R"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Epsilon]", "*", "S", "*", "II"}]}], ")"}], "*", 
       "\[Delta]", "*", "R"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dC", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Epsilon]", "*", "S", "*", "II"}]}], ")"}], "*", 
       "\[Delta]", "*", "R"}], "-", 
      RowBox[{"\[Beta]", "*", "CC", "*", "II"}], "-", 
      RowBox[{"\[Mu]", "*", "CC"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"\[Epsilon]", "*", "S", "*", "II"}]}], ")"}], "*", 
       "\[Gamma]", "*", "CC"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.991032265369727*^9, 3.9910322863212757`*^9}, {
