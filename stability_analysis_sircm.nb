           RowBox[{"-", "1"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", "\[Delta]p"}], ")"}], " ", 
            "\[Sigma]"}]}], ")"}]}], "+", 
        RowBox[{"\[Delta]p", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", "\[Sigma]"}], ")"}], " ", "\[Sigma]", " ", 
         RowBox[{"(", 
