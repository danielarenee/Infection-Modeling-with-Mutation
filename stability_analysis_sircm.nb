           RowBox[{"\[Delta]p", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", 
              RowBox[{"5", " ", "\[Sigma]"}]}], ")"}]}]}], ")"}]}]}], ")"}]}],
      "+", 
     RowBox[{"\[Alpha]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"3", " ", 
         SuperscriptBox["\[Gamma]p", "2"], " ", "\[Delta]p", " ", 
         SuperscriptBox["\[Mu]", "2"]}], "-", 
        RowBox[{"\[Beta]", " ", "\[Gamma]p", " ", "\[Mu]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", "\[Gamma]p", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "2"}], "+", "\[Delta]p", "+", 
              RowBox[{"\[Delta]p", " ", "\[Sigma]"}]}], ")"}]}], "+", 
           RowBox[{"\[Delta]p", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "4"}], "+", 
              RowBox[{"9", " ", "\[Sigma]"}], "+", 
              RowBox[{"2", " ", "\[Delta]p", " ", "\[Sigma]"}]}], ")"}]}]}], 
          ")"}]}], "+", 
        RowBox[{
         SuperscriptBox["\[Beta]", "2"], " ", 
         RowBox[{"(", 
