Cell[BoxData[{
 RowBox[{
  RowBox[{"vars", "=", 
   RowBox[{"{", 
    RowBox[{"S", ",", "II", ",", "R", ",", "CC"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rhs", "=", 
    RowBox[{"{", 
     RowBox[{"dS", ",", "dI", ",", "dR", ",", "dC"}], "}"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"J", "=", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{"rhs", ",", 
       RowBox[{"{", "vars", "}"}]}], "]"}], "//", "Simplify"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"JDFE", "=", 
    RowBox[{
     RowBox[{"J", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "->", "1"}], ",", 
        RowBox[{"II", "->", "0"}], ",", 
        RowBox[{"R", "->", "0"}], ",", 
        RowBox[{"CC", "->", "0"}]}], "}"}]}], "//", "Simplify"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Print", "[", "\"\<Jacobian at DFE:\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"JDFE", "//", "MatrixForm"}], "]"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"evalsDFE", "=", 
   RowBox[{
    RowBox[{"Eigenvalues", "[", "JDFE", "]"}], "//", "Simplify"}]}], ";"}], "\n", 
 RowBox[{"Print", "[", "\"\<\\nEigenvalues at DFE:\>\"", "]"}], "\n", 
 RowBox[{"Print", "[", "evalsDFE", "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.988855936990299*^9, 3.988855949577394*^9}},
 CellLabel->
