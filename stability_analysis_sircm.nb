           RowBox[{"-", "2"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"5", "+", "\[Delta]p"}], ")"}], " ", "\[Sigma]"}]}], 
          ")"}]}]}], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox["\[Beta]", "2"], " ", "\[Mu]", " ", 
